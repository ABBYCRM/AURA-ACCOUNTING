NODE_ENV=development
PORT=4000
DATABASE_PATH=./aura-accounting.sqlite
JWT_SECRET=change-me-32-chars-minimum-please
SESSION_SECRET=change-me-session-secret-32-chars

# QuickBooks Online OAuth 2.0
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=
QBO_REDIRECT_URI=http://localhost:4000/api/qbo/callback
QBO_ENVIRONMENT=sandbox

# Render disk path (when on Render)
# DATABASE_PATH=/var/data/aura-accounting.sqlite
