{
  "name": "aura-accounting-backend",
  "version": "0.1.0",
  "private": true,
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.json && node ../scripts/copy-schema.js",
    "start": "node dist/server.js",
    "dev": "tsc-watch --onSuccess \"node ../scripts/copy-schema.js && node dist/server.js\"",
    "test": "node ../scripts/copy-schema.js && vitest run"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.3.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "pdfkit": "^0.15.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.11",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.7.4",
    "@types/pdfkit": "^0.13.4",
    "@types/supertest": "^7.2.1",
    "supertest": "^7.2.2",
    "tsc-watch": "^6.2.0",
    "typescript": "^5.6.2",
    "vitest": "^2.1.2"
  }
}
